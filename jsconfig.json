{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "jsx": "preserve",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.js",
    "**/*.jsx",
    "**/*.mjs",
    "src/styles/breakpoints.css.ts",
    "src/styles/global.css.ts",
    "src/styles/reset.css.ts",
    "src/styles/tokens.css.ts",
    "src/shared/providers/toast.css.ts",
    "src/app/challenges/[id]/work/[workId]/page.css.ts",
    "src/middleware.js"
  ],
  "exclude": ["node_modules", ".next"]
}
